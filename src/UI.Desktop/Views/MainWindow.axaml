<suki:SukiWindow xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:TowerFluffy.UI.Desktop.ViewModels"
            xmlns:controls="using:TowerFluffy.UI.Desktop.Controls"
            xmlns:suki="using:SukiUI.Controls"
            xmlns:theme="using:SukiUI.Theme"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
            x:Class="TowerFluffy.UI.Desktop.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Icon="avares://TowerFluffy.UI.Desktop/Assets/avalonia-logo.ico"
            Background="{StaticResource BaseBackgroundBrush}"
            Width="1400" Height="800"
            WindowStartupLocation="CenterScreen"
            Title="Tower Fluffy - Tactical Commander">

    <Window.Resources>
        <vm:ReadyToColorConverter x:Key="ReadyToColorConverter" />
        <vm:TowerTypeToBrushConverter x:Key="TowerTypeToBrushConverter" />
        <Color x:Key="BaseBackgroundColor">#05080F</Color>
        <Color x:Key="AccentColor">#00F2FF</Color>
        <Color x:Key="SecondaryColor">#FF00E5</Color>
        <SolidColorBrush x:Key="BaseBackgroundBrush" Color="{StaticResource BaseBackgroundColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    </Window.Resources>

    <Grid>
        <!-- BACKGROUND AMBIANCE -->
        <Canvas ZIndex="-1" Opacity="0.3">
            <Ellipse Width="600" Height="600" Fill="#2000F2FF" Canvas.Left="-100" Canvas.Top="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="100" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="500" Height="500" Fill="#20FF00E5" Canvas.Right="-100" Canvas.Bottom="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="100" />
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- MAIN MENU (TWO COLUMNS) -->
        <Border IsVisible="{Binding IsConnectionVisible}" ZIndex="300" Padding="50">
            <StackPanel VerticalAlignment="Center" Spacing="50">
                <!-- HEADER -->
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="TOWER FLUFFY" FontSize="72" FontWeight="Black" LetterSpacing="15" HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Offset="0" Color="{StaticResource AccentColor}" />
                                <GradientStop Offset="1" Color="{StaticResource SecondaryColor}" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="DÉPLOIEMENT TACTIQUE V1.1" FontSize="14" Opacity="0.5" FontWeight="Bold" LetterSpacing="5" HorizontalAlignment="Center" />
                </StackPanel>

                <Grid ColumnDefinitions="*,1.2*" ColumnSpacing="40" MaxWidth="1200" HorizontalAlignment="Center">
                    <!-- LEFT: NETWORK & LOBBY -->
                    <suki:GlassCard Grid.Column="0" VerticalAlignment="Stretch">
                        <StackPanel Spacing="25">
                            <StackPanel Spacing="10">
                                <TextBlock Text="SYSTÈME RÉSEAU" FontWeight="Bold" FontSize="12" Opacity="0.7" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <TextBox Text="{Binding ServerUrl}" Watermark="URL du Hub..." Classes="Primary" />
                                    <Button Grid.Column="1" Content="SCANNER" Command="{Binding ConnectCommand}" Classes="Flat" />
                                </Grid>
                            </StackPanel>

                            <Separator Opacity="0.1" />

                            <StackPanel Spacing="15">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="MISSIONS ACTIVES" FontWeight="Bold" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="RAFRAÎCHIR" Command="{Binding RefreshGamesCommand}" IsEnabled="{Binding IsConnected}" Classes="Basic" FontSize="10" />
                                </Grid>

                                <ListBox ItemsSource="{Binding AvailableGames}" Background="Transparent" Height="300" CornerRadius="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <suki:GlassCard Margin="0,4" Padding="15">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="{Binding GameId}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentBrush}" />
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <Border Background="#20FFFFFF" CornerRadius="4" Padding="6,2">
                                                                <TextBlock Text="{Binding PlayerCount, StringFormat='{}{0}/2 Joueurs'}" FontSize="10" Opacity="0.7" />
                                                            </Border>
                                                            <TextBlock Text="EN ATTENTE" FontSize="10" Foreground="#00FF00" IsVisible="{Binding !IsStarted}" Opacity="0.8" />
                                                            <TextBlock Text="EN COURS" FontSize="10" Foreground="{StaticResource SecondaryBrush}" IsVisible="{Binding IsStarted}" FontWeight="Bold" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="REJOINDRE" Classes="Flat" IsVisible="{Binding !IsStarted}" 
                                                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).JoinSpecificGameCommand}" 
                                                            CommandParameter="{Binding GameId}" />
                                                </Grid>
                                            </suki:GlassCard>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border IsVisible="{Binding !IsConnected}" Height="300" Background="#10FFFFFF" CornerRadius="12">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                                        <ProgressBar IsIndeterminate="True" Width="100" IsVisible="{Binding IsConnecting}" />
                                        <TextBlock Text="EN ATTENTE DE CONNEXION..." Opacity="0.4" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </suki:GlassCard>

                    <!-- RIGHT: PILOT CONFIG & LAUNCH -->
                    <suki:GlassCard Grid.Column="1" VerticalAlignment="Stretch" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                        <StackPanel Spacing="40">
                            <StackPanel Spacing="20">
                                <TextBlock Text="CONFIGURATION DE L'UNITÉ" FontWeight="Bold" FontSize="12" Opacity="0.7" />
                                
                                <StackPanel Spacing="10">
                                    <TextBlock Text="PROFIL DE MISSION" FontSize="14" />
                                    <ComboBox SelectedIndex="{Binding SelectedRole}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem>ENTRAÎNEMENT SOLO (Défense + Attaque)</ComboBoxItem>
                                        <ComboBoxItem>UNITÉ D'ASSAUT (Attaquant)</ComboBoxItem>
                                        <ComboBoxItem>UNITÉ DE PROTECTION (Défenseur)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="10" IsVisible="{Binding !IsSoloMode}">
                                    <TextBlock Text="NOM DE LA SALLE DE GUERRE" FontSize="14" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                                        <TextBox x:Name="RoomName" Watermark="Ex: Alpha-Sector-9..." IsEnabled="{Binding IsConnected}" />
                                        <Button Grid.Column="1" Content="REJOINDRE / CRÉER" Command="{Binding JoinSpecificGameCommand}" 
                                                CommandParameter="{Binding #RoomName.Text}" IsEnabled="{Binding IsConnected}" Classes="Flat" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <Separator Opacity="0.1" />

                            <StackPanel Spacing="20" VerticalAlignment="Bottom">
                                <Button IsVisible="{Binding IsSoloMode}" Command="{Binding StartSoloCommand}" 
                                        HorizontalAlignment="Stretch" Height="100" Classes="Flat">
                                    <Button.Background>
                                        <LinearGradientBrush>
                                            <GradientStop Offset="0" Color="{StaticResource AccentColor}" />
                                            <GradientStop Offset="1" Color="#00A0FF" />
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <StackPanel Orientation="Horizontal" Spacing="25">
                                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="Black" Width="40" Height="40" Stretch="Uniform" />
                                        <TextBlock Text="LANCER L'OPÉRATION" FontSize="28" FontWeight="Black" Foreground="Black" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Border IsVisible="{Binding !IsSoloMode}" Padding="20" Background="#10FFFFFF" CornerRadius="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="PRÊT POUR LE MULTIJOUEUR" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Sélectionnez une mission à gauche pour vous connecter au champ de bataille." Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                                        Background="#40FF0000" Padding="15" CornerRadius="8" BorderBrush="#80FF0000" BorderThickness="1">
                                    <TextBlock Text="{Binding LastError}" Foreground="White" FontWeight="Bold" TextWrapping="Wrap" HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </suki:GlassCard>
                </Grid>
            </StackPanel>
        </Border>

        <!-- WAITING ROOM -->
        <Border Background="#F005080F" IsVisible="{Binding IsWaitingRoomVisible}" ZIndex="250">
            <suki:GlassCard VerticalAlignment="Center" HorizontalAlignment="Center" Width="600" Padding="40">
                <StackPanel Spacing="40">
                    <TextBlock Text="PRÉPARATION DU DÉPLOIEMENT" FontSize="32" FontWeight="Black" HorizontalAlignment="Center" LetterSpacing="5" />
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="30">
                        <suki:GlassCard Grid.Column="0">
                            <StackPanel Spacing="20" HorizontalAlignment="Center">
                                <TextBlock Text="PILOTE" FontWeight="Bold" Opacity="0.6" HorizontalAlignment="Center" />
                                <Ellipse Width="50" Height="50" Fill="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" />
                                <CheckBox Content="PRÊT" IsChecked="{Binding IsReady}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </suki:GlassCard>

                        <suki:GlassCard Grid.Column="1">
                            <StackPanel Spacing="20" HorizontalAlignment="Center">
                                <TextBlock Text="ADVERSAIRE" FontWeight="Bold" Opacity="0.6" HorizontalAlignment="Center" />
                                <Ellipse Width="50" Height="50" Fill="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" />
                                <TextBlock Text="IDENTIFICATION..." Opacity="0.5" FontSize="10" />
                            </StackPanel>
                        </suki:GlassCard>
                    </Grid>

                    <ProgressBar IsIndeterminate="True" />
                    
                    <Button Content="ABANDONNER LA MISSION" Command="{Binding ReplayCommand}" Classes="Basic" HorizontalAlignment="Center" />
                </StackPanel>
            </suki:GlassCard>
        </Border>

        <!-- GAME UI (Remains mostly native but with Suki touches if needed) -->
        <Grid IsVisible="{Binding IsGameStarted}" RowDefinitions="Auto,*" ColumnDefinitions="Auto,*,Auto" Margin="30">
            <!-- TOP HUD -->
            <suki:GlassCard Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,20" Padding="20,10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="40">
                        <StackPanel>
                            <TextBlock Text="TOWER FLUFFY" FontWeight="Black" FontSize="18" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="LIVE TACTICAL FEED" FontSize="10" Opacity="0.5" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <Border Background="#20FF2E2E" Padding="15,5" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="COEUR:" FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Snapshot.Hud.BaseHealth}" FontSize="24" FontWeight="Bold" Foreground="#FF2E2E" />
                                </StackPanel>
                            </Border>
                            <Border Background="#2000F2FF" Padding="15,5" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="VAGUE:" FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Snapshot.Hud.WaveNumber}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="QUITTER" Command="{Binding ReplayCommand}" Classes="Basic" />
                </Grid>
            </suki:GlassCard>

            <!-- GAME BOARD (Middle) -->
            <suki:GlassCard Grid.Row="1" Grid.Column="1" Padding="0" ClipToBounds="True">
                <Viewbox Stretch="Uniform">
                    <controls:GameBoardControl Snapshot="{Binding Snapshot}" PlaceTowerCommand="{Binding PlaceTowerCommand}" Margin="50" />
                </Viewbox>
            </suki:GlassCard>
            
            <!-- (Side panels can be restored here as needed) -->
        </Grid>
    </Grid>
</suki:SukiWindow>

<suki:SukiWindow xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:TowerFluffy.UI.Desktop.ViewModels"
            xmlns:controls="using:TowerFluffy.UI.Desktop.Controls"
            xmlns:suki="using:SukiUI.Controls"
            xmlns:theme="using:SukiUI.Theme"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
            x:Class="TowerFluffy.UI.Desktop.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Background="#0D0F14"
            MinWidth="1000" MinHeight="700"
            WindowStartupLocation="CenterScreen"
            Title="TowerFluffy">

    <Window.Resources>
        <vm:ReadyToColorConverter x:Key="ReadyToColorConverter" />
        <vm:TowerTypeToBrushConverter x:Key="TowerTypeToBrushConverter" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00A3FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#1F242E" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
    </Window.Resources>

    <Grid>
        <!-- LOBBY PRINCIPAL -->
        <Border IsVisible="{Binding IsConnectionVisible}" Padding="40">
            <Grid RowDefinitions="Auto, *">
                <StackPanel Grid.Row="0" Margin="0,0,0,40">
                    <Viewbox Height="40" Stretch="Uniform">
                        <TextBlock Text="TOWER FLUFFY" FontWeight="Light" LetterSpacing="10" />
                    </Viewbox>
                    <Rectangle Height="1" Fill="{StaticResource AccentBrush}" Width="40" Margin="0,10" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="*, 350" ColumnSpacing="40" MaxWidth="1200" HorizontalAlignment="Center">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                            <TextBlock Text="PARTIES ACTIVES" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Rafraîchir" Command="{Binding RefreshGamesCommand}" Classes="Basic" FontSize="11" />
                        </Grid>
                        <Border Grid.Row="1" Background="#151921" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ListBox ItemsSource="{Binding AvailableGames}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding GameId}" FontWeight="SemiBold" FontSize="15" />
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding PlayerCount, StringFormat='Joueurs : {0}/2'}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                                        <Ellipse Width="5" Height="5" Fill="#10B981" VerticalAlignment="Center" IsVisible="{Binding !IsStarted}" />
                                                        <TextBlock Text="Disponible" FontSize="11" Foreground="#10B981" IsVisible="{Binding !IsStarted}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Rejoindre" Classes="Flat" 
                                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).JoinSpecificGameCommand}" 
                                                        CommandParameter="{Binding GameId}" IsVisible="{Binding !IsStarted}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                    <StackPanel Grid.Column="1" Spacing="30">
                        <StackPanel Spacing="12">
                            <TextBlock Text="MISSION" FontWeight="Bold" FontSize="13" />
                            <ComboBox SelectedIndex="{Binding SelectedRole}" HorizontalAlignment="Stretch" Background="#151921" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8">
                                <ComboBoxItem>Entraînement Solo</ComboBoxItem>
                                <ComboBoxItem>Assaut (Attaquant)</ComboBoxItem>
                                <ComboBoxItem>Protection (Défenseur)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="12" IsVisible="{Binding !IsSoloMode}">
                            <TextBlock Text="CRÉER" FontWeight="Bold" FontSize="13" />
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                <TextBox x:Name="RoomName" Watermark="Nom de salle..." Background="#151921" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" />
                                <Button Grid.Column="1" Content="Créer" Command="{Binding JoinSpecificGameCommand}" CommandParameter="{Binding #RoomName.Text}" Classes="Flat" />
                            </Grid>
                        </StackPanel>
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,5" />
                        <Button IsVisible="{Binding IsSoloMode}" Command="{Binding StartSoloCommand}" Classes="Flat" Background="{StaticResource AccentBrush}" Foreground="White" Height="50" CornerRadius="8" HorizontalAlignment="Stretch">
                            <TextBlock Text="LANCER" FontWeight="Bold" LetterSpacing="2" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- SALLE D'ATTENTE -->
        <Border Background="#F00D0F14" IsVisible="{Binding IsWaitingRoomVisible}" ZIndex="250">
            <Viewbox MaxHeight="500" Stretch="Uniform" Margin="40">
                <StackPanel Spacing="50">
                    <TextBlock Text="PRÉPARATION" FontSize="24" FontWeight="Light" LetterSpacing="8" HorizontalAlignment="Center" />
                    <Grid ColumnDefinitions="250, 250" ColumnSpacing="40">
                        <Border Grid.Column="0" Background="#151921" CornerRadius="12" Padding="30" BorderBrush="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <TextBlock Text="VOUS" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Opacity="0.5" />
                                <CheckBox IsChecked="{Binding IsReady}" HorizontalAlignment="Center" Content="PRÊT" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#151921" CornerRadius="12" Padding="30" BorderBrush="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <TextBlock Text="ADVERSAIRE" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Opacity="0.5" />
                                <TextBlock Text="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}, ConverterParameter=StatusText}" HorizontalAlignment="Center" FontSize="16" FontWeight="Black" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Button Content="Abandonner" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" HorizontalAlignment="Center" />
                </StackPanel>
            </Viewbox>
        </Border>

        <!-- HUD EN JEU -->
        <Grid IsVisible="{Binding IsGameStarted}" RowDefinitions="Auto, *, Auto" Margin="20">
            <Border Grid.Row="0" Background="#151921" CornerRadius="12" Padding="20,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,15">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <TextBlock Text="TOWER FLUFFY" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="40">
                        <StackPanel>
                            <TextBlock Text="BASE" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Snapshot.Hud.BaseHealth}" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="VAGUE" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Snapshot.Hud.WaveNumber}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Content="TERMINER" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" Height="30" Padding="15,0" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto">
                <Border Grid.Column="0" Width="200" Background="#151921" CornerRadius="12" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" IsVisible="{Binding CanPlaceTower}">
                    <StackPanel Spacing="15">
                        <TextBlock Text="DÉFENSE" FontWeight="Bold" Opacity="0.4" FontSize="10" HorizontalAlignment="Center" />
                        <Border Background="#00A3FF" Opacity="0.1" CornerRadius="8" Padding="10">
                            <TextBlock Text="{Binding Snapshot.Hud.DefenderGold, StringFormat='{}{0} CR'}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="8">
                            <Button Command="{Binding SetBasicTowerCommand}" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=BasicShooter}" HorizontalAlignment="Stretch" CornerRadius="8" Height="40">
                                <TextBlock Text="Standard" FontSize="11" />
                            </Button>
                            <Button Command="{Binding SetFlamethrowerCommand}" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=Flamethrower}" HorizontalAlignment="Stretch" CornerRadius="8" Height="40">
                                <TextBlock Text="Flammes" FontSize="11" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Viewbox Grid.Column="1" Stretch="Uniform" Margin="20,0">
                    <controls:GameBoardControl Snapshot="{Binding Snapshot}" PlaceTowerCommand="{Binding PlaceTowerCommand}" />
                </Viewbox>

                <Border Grid.Column="2" Width="200" Background="#151921" CornerRadius="12" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" IsVisible="{Binding CanSendUnits}">
                    <StackPanel Spacing="15">
                        <TextBlock Text="ATTAQUE" FontWeight="Bold" Opacity="0.4" FontSize="10" HorizontalAlignment="Center" />
                        <Border Background="#EF4444" Opacity="0.1" CornerRadius="8" Padding="10">
                            <TextBlock Text="{Binding Snapshot.Hud.AttackerBudget, StringFormat='{}{0} CR'}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="8">
                            <Button Command="{Binding SendSoldatCommand}" HorizontalAlignment="Stretch" CornerRadius="8" Height="40">
                                <TextBlock Text="Soldat" FontSize="11" />
                            </Button>
                            <Button Command="{Binding SendBruteCommand}" HorizontalAlignment="Stretch" CornerRadius="8" Height="40">
                                <TextBlock Text="Brute" FontSize="11" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#151921" CornerRadius="12" Padding="20,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,15,0,0">
                <Grid ColumnDefinitions="*, Auto, *">
                    <TextBlock Grid.Column="0" Text="SYSTÈME ACTIF" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding ActivePhaseLabel}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="11" />
                        <TextBlock Text="{Binding ActivePhaseTime}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding SkipPreparationCommand}" IsVisible="{Binding IsPreparationTimerVisible}" Content="VAGUE SUIVANTE" Classes="Flat" Height="30" FontSize="10" HorizontalAlignment="Right" Padding="15,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>

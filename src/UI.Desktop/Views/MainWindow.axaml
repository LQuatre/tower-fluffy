<suki:SukiWindow xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:TowerFluffy.UI.Desktop.ViewModels"
            xmlns:controls="using:TowerFluffy.UI.Desktop.Controls"
            xmlns:suki="using:SukiUI.Controls"
            xmlns:theme="using:SukiUI.Theme"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
            x:Class="TowerFluffy.UI.Desktop.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Background="#0D0F14"
            MinWidth="1000" MinHeight="700"
            WindowStartupLocation="CenterScreen"
            Title="TowerFluffy">

    <Window.Resources>
        <vm:ReadyToColorConverter x:Key="ReadyToColorConverter" />
        <vm:TowerTypeToBrushConverter x:Key="TowerTypeToBrushConverter" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00A3FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#1F242E" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
    </Window.Resources>

    <Grid>
        <!-- MENU PRINCIPAL -->
        <Border IsVisible="{Binding IsConnectionVisible}" Padding="40">
            <Grid RowDefinitions="Auto, *">
                
                <StackPanel Grid.Row="0" Margin="0,0,0,40">
                    <Viewbox Height="40" Stretch="Uniform" HorizontalAlignment="Center">
                        <TextBlock Text="TowerFluffy" FontWeight="Light" LetterSpacing="2" />
                    </Viewbox>
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="*, 350" ColumnSpacing="40" MaxWidth="1100" HorizontalAlignment="Center">
                    
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="Parties disponibles" FontWeight="Bold" Margin="0,0,0,15" />
                        <Border Grid.Row="1" Background="#151921" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ListBox ItemsSource="{Binding AvailableGames}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding GameId}" FontWeight="SemiBold" FontSize="15" />
                                                    <TextBlock Text="{Binding PlayerCount, StringFormat='{}{0} / 2 joueurs'}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Rejoindre" Classes="Flat" 
                                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).JoinSpecificGameCommand}" 
                                                        CommandParameter="{Binding GameId}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" Spacing="30">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Mode de jeu" FontWeight="Bold" />
                            <ComboBox SelectedIndex="{Binding SelectedRole}" HorizontalAlignment="Stretch" Background="#151921">
                                <ComboBoxItem>Solo</ComboBoxItem>
                                <ComboBoxItem>Attaquant</ComboBoxItem>
                                <ComboBoxItem>Défenseur</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="10" IsVisible="{Binding !IsSoloMode}">
                            <TextBlock Text="Nouvelle salle" FontWeight="Bold" />
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                <TextBox x:Name="RoomName" Watermark="Nom..." Background="#151921" />
                                <Button Grid.Column="1" Content="Créer" Command="{Binding JoinSpecificGameCommand}" CommandParameter="{Binding #RoomName.Text}" Classes="Flat" />
                            </Grid>
                        </StackPanel>

                        <Button IsVisible="{Binding IsSoloMode}" Command="{Binding StartSoloCommand}" 
                                Classes="Flat" Background="{StaticResource AccentBrush}" Foreground="White" 
                                Height="50" HorizontalAlignment="Stretch">
                            <TextBlock Text="Jouer" FontWeight="Bold" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ATTENTE -->
        <Border Background="#F00D0F14" IsVisible="{Binding IsWaitingRoomVisible}" ZIndex="250">
            <Viewbox MaxHeight="400" Stretch="Uniform" Margin="40">
                <StackPanel Spacing="40">
                    <TextBlock Text="En attente des joueurs" FontSize="20" HorizontalAlignment="Center" />
                    <Grid ColumnDefinitions="200, 200" ColumnSpacing="20">
                        <Border Grid.Column="0" Background="#151921" CornerRadius="8" Padding="20" BorderBrush="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                            <CheckBox IsChecked="{Binding IsReady}" Content="Moi : Prêt" HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" Background="#151921" CornerRadius="8" Padding="20" BorderBrush="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                            <TextBlock Text="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}, ConverterParameter=StatusText, StringFormat='Adversaire : {0}'}" HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                    <Button Content="Quitter" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" HorizontalAlignment="Center" />
                </StackPanel>
            </Viewbox>
        </Border>

        <!-- JEU -->
        <Grid IsVisible="{Binding IsGameStarted}" RowDefinitions="Auto, *, Auto" Margin="20">
            
            <Border Grid.Row="0" Background="#151921" CornerRadius="8" Padding="20,10" Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <TextBlock Text="TowerFluffy" VerticalAlignment="Center" FontWeight="Bold" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="50">
                        <Viewbox Height="40">
                            <StackPanel>
                                <TextBlock Text="Vie de la base" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.BaseHealth}" FontWeight="Bold" />
                            </StackPanel>
                        </Viewbox>
                        <Viewbox Height="40">
                            <StackPanel>
                                <TextBlock Text="Vague" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.WaveNumber}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Viewbox>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Quitter" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="180, *, 180">
                <Border Grid.Column="0" Background="#151921" CornerRadius="8" Padding="15" IsVisible="{Binding CanPlaceTower}">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Défense" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Snapshot.Hud.DefenderGold, StringFormat='{}{0} Or'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                        <Button Command="{Binding SetBasicTowerCommand}" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=BasicShooter}" HorizontalAlignment="Stretch" Content="Tour" />
                        <Button Command="{Binding SetFlamethrowerCommand}" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=Flamethrower}" HorizontalAlignment="Stretch" Content="Feu" />
                    </StackPanel>
                </Border>

                <Viewbox Grid.Column="1" Stretch="Uniform" Margin="20,0">
                    <controls:GameBoardControl Snapshot="{Binding Snapshot}" PlaceTowerCommand="{Binding PlaceTowerCommand}" />
                </Viewbox>

                <Border Grid.Column="2" Background="#151921" CornerRadius="8" Padding="15" IsVisible="{Binding CanSendUnits}">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Attaque" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Snapshot.Hud.AttackerBudget, StringFormat='{}{0} Or'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                        <Button Command="{Binding SendSoldatCommand}" HorizontalAlignment="Stretch" Content="+ Soldat" />
                        <Button Command="{Binding SendBruteCommand}" HorizontalAlignment="Stretch" Content="+ Brute" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#151921" CornerRadius="8" Padding="20,10" Margin="0,10,0,0">
                <Grid ColumnDefinitions="*, Auto, *">
                    <TextBlock Text="En cours..." FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding ActivePhaseLabel}" VerticalAlignment="Center" />
                        <Viewbox Height="30">
                            <TextBlock Text="{Binding ActivePhaseTime}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </Viewbox>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding SkipPreparationCommand}" IsVisible="{Binding IsPreparationTimerVisible}" Content="Vague suivante" Classes="Flat" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>

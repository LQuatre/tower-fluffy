<suki:SukiWindow xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:TowerFluffy.UI.Desktop.ViewModels"
            xmlns:controls="using:TowerFluffy.UI.Desktop.Controls"
            xmlns:suki="using:SukiUI.Controls"
            xmlns:theme="using:SukiUI.Theme"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
            x:Class="TowerFluffy.UI.Desktop.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Background="#0D0F14"
            Width="1300" Height="800"
            WindowStartupLocation="CenterScreen"
            Title="TowerFluffy">

    <Window.Resources>
        <vm:ReadyToColorConverter x:Key="ReadyToColorConverter" />
        <vm:TowerTypeToBrushConverter x:Key="TowerTypeToBrushConverter" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00A3FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#1F242E" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
    </Window.Resources>

    <Grid>
        <!-- LOBBY PRINCIPAL : SIMPLE & CLEAN -->
        <Border IsVisible="{Binding IsConnectionVisible}" Padding="80">
            <Grid RowDefinitions="Auto, *">
                
                <!-- HEADER MINIMALISTE -->
                <StackPanel Grid.Row="0" Margin="0,0,0,60">
                    <TextBlock Text="TOWER FLUFFY" FontSize="32" FontWeight="Light" LetterSpacing="10" HorizontalAlignment="Center" />
                    <Rectangle Height="1" Fill="{StaticResource AccentBrush}" Width="60" Margin="0,15" />
                    <TextBlock Text="PLATEFORME DE SIMULATION TACTIQUE" FontSize="11" Foreground="{StaticResource MutedTextBrush}" LetterSpacing="4" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- CONTENU -->
                <Grid Grid.Row="1" ColumnDefinitions="*, 400" ColumnSpacing="60" MaxWidth="1100" HorizontalAlignment="Center">
                    
                    <!-- GAUCHE : LISTE DES PARTIES -->
                    <StackPanel Grid.Column="0" Spacing="25">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="PARTIES ACTIVES" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Rafraîchir" Command="{Binding RefreshGamesCommand}" Classes="Basic" FontSize="11" />
                        </Grid>
                        
                        <Border Background="#151921" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <ListBox ItemsSource="{Binding AvailableGames}" Background="Transparent" Height="400" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,15">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="{Binding GameId}" FontWeight="SemiBold" FontSize="16" />
                                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                                            <TextBlock Text="{Binding PlayerCount, StringFormat='Joueurs : {0}/2'}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                            <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center" IsVisible="{Binding !IsStarted}" />
                                                            <TextBlock Text="En attente" FontSize="12" Foreground="#10B981" IsVisible="{Binding !IsStarted}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Rejoindre" Classes="Flat" 
                                                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).JoinSpecificGameCommand}" 
                                                            CommandParameter="{Binding GameId}" IsVisible="{Binding !IsStarted}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <!-- ETAT DE CONNEXION -->
                                <StackPanel IsVisible="{Binding !IsConnected}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                                    <TextBlock Text="Connexion au serveur..." Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                    <ProgressBar IsIndeterminate="True" Width="100" Height="2" Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- DROITE : ACTIONS -->
                    <StackPanel Grid.Column="1" Spacing="40">
                        <StackPanel Spacing="15">
                            <TextBlock Text="PROFIL DE MISSION" FontWeight="Bold" FontSize="14" />
                            <ComboBox SelectedIndex="{Binding SelectedRole}" HorizontalAlignment="Stretch" Background="#151921" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8">
                                <ComboBoxItem>Entraînement Solo</ComboBoxItem>
                                <ComboBoxItem>Unité d'Assaut (Attaquant)</ComboBoxItem>
                                <ComboBoxItem>Unité de Protection (Défenseur)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="15" IsVisible="{Binding !IsSoloMode}">
                            <TextBlock Text="CRÉER UNE SALLE" FontWeight="Bold" FontSize="14" />
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                <TextBox x:Name="RoomName" Watermark="Nom de la salle..." Background="#151921" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" />
                                <Button Grid.Column="1" Content="Créer" Command="{Binding JoinSpecificGameCommand}" CommandParameter="{Binding #RoomName.Text}" Classes="Flat" />
                            </Grid>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,10" />

                        <Button IsVisible="{Binding IsSoloMode}" Command="{Binding StartSoloCommand}" 
                                Classes="Flat" Background="{StaticResource AccentBrush}" Foreground="White" 
                                Height="60" CornerRadius="8" HorizontalAlignment="Stretch">
                            <TextBlock Text="COMMENCER" FontWeight="Bold" LetterSpacing="2" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- SALLE D'ATTENTE (CLEAN) -->
        <Border Background="#F00D0F14" IsVisible="{Binding IsWaitingRoomVisible}" ZIndex="250">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="60">
                <TextBlock Text="PRÉPARATION" FontSize="24" FontWeight="Light" LetterSpacing="8" HorizontalAlignment="Center" />
                
                <Grid ColumnDefinitions="250, 250" ColumnSpacing="40">
                    <Border Grid.Column="0" Background="#151921" CornerRadius="12" Padding="30" BorderBrush="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                        <StackPanel Spacing="20">
                            <TextBlock Text="VOUS" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Opacity="0.5" />
                            <CheckBox IsChecked="{Binding IsReady}" HorizontalAlignment="Center" Content="PRÊT" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#151921" CornerRadius="12" Padding="30" BorderBrush="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="1">
                        <StackPanel Spacing="20">
                            <TextBlock Text="ADVERSAIRE" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Opacity="0.5" />
                            <TextBlock Text="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}, ConverterParameter=StatusText}" 
                                       HorizontalAlignment="Center" FontSize="16" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Content="Quitter la salle" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- HUD EN JEU (PROPRE & EFFICACE) -->
        <Grid IsVisible="{Binding IsGameStarted}" RowDefinitions="Auto, *, Auto" Margin="30">
            
            <!-- BARRE SUPÉRIEURE -->
            <Border Grid.Row="0" Background="#151921" CornerRadius="12" Padding="20,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*, *, *">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="TOWER FLUFFY" FontWeight="Bold" FontSize="12" />
                        <TextBlock Text="Mission en cours" FontSize="10" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="40">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="BASE" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Snapshot.Hud.BaseHealth}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="VAGUE" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Snapshot.Hud.WaveNumber}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2" Content="ABANDONNER" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="#EF4444" HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- ZONE DE JEU -->
            <Grid Grid.Row="1" ColumnDefinitions="260, *, 260" Margin="0,25">
                
                <!-- PANEL GAUCHE (DÉFENSE) -->
                <Border Grid.Column="0" Background="#151921" CornerRadius="12" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" IsVisible="{Binding CanPlaceTower}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="DÉFENSE" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center" />
                        <Border Background="#00A3FF" Opacity="0.1" CornerRadius="8" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="CRÉDITS" FontSize="10" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.DefenderGold}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Spacing="10">
                            <Button Command="{Binding SetBasicTowerCommand}" HorizontalAlignment="Stretch" Height="50" CornerRadius="8" 
                                    Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=BasicShooter}">
                                <TextBlock Text="Tour Standard" FontSize="12" />
                            </Button>
                            <Button Command="{Binding SetFlamethrowerCommand}" HorizontalAlignment="Stretch" Height="50" CornerRadius="8"
                                    Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=Flamethrower}">
                                <TextBlock Text="Lance-flammes" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- TERRAIN -->
                <Viewbox Grid.Column="1" Stretch="Uniform" Margin="20,0">
                    <controls:GameBoardControl Snapshot="{Binding Snapshot}" PlaceTowerCommand="{Binding PlaceTowerCommand}" />
                </Viewbox>

                <!-- PANEL DROIT (ATTAQUE) -->
                <Border Grid.Column="2" Background="#151921" CornerRadius="12" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" IsVisible="{Binding CanSendUnits}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="ATTAQUE" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center" />
                        <Border Background="#EF4444" Opacity="0.1" CornerRadius="8" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="BUDGET" FontSize="10" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.AttackerBudget}" FontSize="20" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Spacing="10">
                            <Button Command="{Binding SendSoldatCommand}" HorizontalAlignment="Stretch" Height="50" CornerRadius="8">
                                <TextBlock Text="Envoyer Soldat" FontSize="12" />
                            </Button>
                            <Button Command="{Binding SendBruteCommand}" HorizontalAlignment="Stretch" Height="50" CornerRadius="8">
                                <TextBlock Text="Envoyer Brute" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- BARRE INFÉRIEURE -->
            <Border Grid.Row="2" Background="#151921" CornerRadius="12" Padding="20,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*, Auto, *">
                    <TextBlock Grid.Column="0" Text="Simulation active" FontSize="11" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding ActivePhaseLabel}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Text="{Binding ActivePhaseTime}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="2" Command="{Binding SkipPreparationCommand}" IsVisible="{Binding IsPreparationTimerVisible}" 
                            Content="Démarrer Vague" Classes="Flat" Height="35" FontSize="11" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>

<suki:SukiWindow xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:TowerFluffy.UI.Desktop.ViewModels"
            xmlns:controls="using:TowerFluffy.UI.Desktop.Controls"
            xmlns:suki="using:SukiUI.Controls"
            xmlns:theme="using:SukiUI.Theme"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
            x:Class="TowerFluffy.UI.Desktop.Views.MainWindow"
            x:DataType="vm:MainWindowViewModel"
            Icon="avares://TowerFluffy.UI.Desktop/Assets/avalonia-logo.ico"
            Background="#020408"
            Width="1400" Height="850"
            WindowStartupLocation="CenterScreen"
            Title="TOWER FLUFFY - LIAISON TACTIQUE">

    <Window.Resources>
        <vm:ReadyToColorConverter x:Key="ReadyToColorConverter" />
        <vm:TowerTypeToBrushConverter x:Key="TowerTypeToBrushConverter" />
        <Color x:Key="HudAmber">#FFB000</Color>
        <Color x:Key="HudBlue">#00A3FF</Color>
        <Color x:Key="HudDanger">#FF3C00</Color>
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource HudAmber}" />
        <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource HudBlue}" />
    </Window.Resources>

    <Grid>
        <!-- COUCHE DE FOND TACTIQUE -->
        <Grid ZIndex="-1">
            <Rectangle Fill="#0AFFFFFF" Opacity="0.05">
                <Rectangle.Fill>
                    <VisualBrush TileMode="Tile" SourceRect="0,0,1,2" DestinationRect="0,0,1,2">
                        <VisualBrush.Visual>
                            <Rectangle Height="1" Width="1" Fill="White" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Canvas Opacity="0.15">
                <Ellipse Width="800" Height="800" Fill="#1000A3FF" Canvas.Left="-200" Canvas.Top="-100"><Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect></Ellipse>
                <Ellipse Width="600" Height="600" Fill="#10FFB000" Canvas.Right="-100" Canvas.Bottom="-100"><Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect></Ellipse>
            </Canvas>
        </Grid>

        <!-- INTERFACE TERMINAL PRINCIPALE (LOBBY) -->
        <Border IsVisible="{Binding IsConnectionVisible}" Padding="60">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,40">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="STATUT LIAISON : SÉCURISÉ" FontSize="10" Foreground="{StaticResource BlueBrush}" FontWeight="Bold" LetterSpacing="2" />
                        <TextBlock Text="PROTOCOLE : FLUFFY-v1.1" FontSize="10" Opacity="0.4" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="TOWER FLUFFY" FontSize="64" FontWeight="Black" Foreground="White" LetterSpacing="20" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="15" Color="{StaticResource HudBlue}" Opacity="0.3" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <Rectangle Height="1" Fill="{StaticResource BlueBrush}" Width="400" Opacity="0.3" Margin="0,10" />
                        <TextBlock Text="CENTRE DE COMMANDEMENT ET DÉPLOIEMENT" FontSize="12" Foreground="{StaticResource AmberBrush}" FontWeight="Bold" LetterSpacing="8" HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="5" HorizontalAlignment="Right">
                        <TextBlock Text="SECTEUR : LQUATRE-PRIME" FontSize="10" Foreground="{StaticResource BlueBrush}" FontWeight="Bold" HorizontalAlignment="Right" />
                        <TextBlock Text="CHIFFREMENT : MSG-PACK" FontSize="10" Opacity="0.4" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*, 1.2*" ColumnSpacing="40" MaxWidth="1300" HorizontalAlignment="Center">
                    <Grid Grid.Column="0" RowDefinitions="Auto, *">
                        <Border BorderBrush="{StaticResource BlueBrush}" BorderThickness="2,2,0,0" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <Border BorderBrush="{StaticResource BlueBrush}" BorderThickness="0,0,2,2" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                        <StackPanel Spacing="30" Margin="20">
                            <StackPanel Spacing="15">
                                <TextBlock Text="[ 01 ] FLUX DE DONNÉES" FontWeight="Black" FontSize="14" Foreground="{StaticResource BlueBrush}" />
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
                                    <TextBox Text="{Binding ServerUrl}" IsReadOnly="True" Background="#15FFFFFF" BorderBrush="#30FFFFFF" CornerRadius="0" Padding="10" />
                                    <Border Background="{StaticResource BlueBrush}" Padding="15,0" VerticalAlignment="Stretch">
                                        <TextBlock Text="LIAISON ACTIVE" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center" FontSize="10" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="[ 02 ] MISSIONS DISPONIBLES" FontWeight="Black" FontSize="14" Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="ACTUALISER" Command="{Binding RefreshGamesCommand}" IsEnabled="{Binding IsConnected}" Classes="Basic" FontSize="10" Foreground="{StaticResource AmberBrush}" />
                                </Grid>
                                <ListBox ItemsSource="{Binding AvailableGames}" Background="#08FFFFFF" Height="350" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#10FFFFFF" Margin="0,1" Padding="15">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding GameId}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource AmberBrush}" />
                                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                                            <TextBlock Text="{Binding PlayerCount, StringFormat='UNITÉS : {0}/2'}" FontSize="10" Opacity="0.6" />
                                                            <TextBlock Text="ÉTAT : ATTENTE" FontSize="10" Foreground="#00FF00" IsVisible="{Binding !IsStarted}" FontWeight="Bold" />
                                                            <TextBlock Text="ÉTAT : EN COMBAT" FontSize="10" Foreground="#FF3C00" IsVisible="{Binding IsStarted}" FontWeight="Bold" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="INTERCEPTER" Classes="Flat" IsVisible="{Binding !IsStarted}" 
                                                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).JoinSpecificGameCommand}" 
                                                            CommandParameter="{Binding GameId}" Background="{StaticResource AmberBrush}" Foreground="Black" FontWeight="Black" CornerRadius="0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border IsVisible="{Binding !IsConnected}" Height="350" Background="#05FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                                        <TextBlock Text="SYNCHRONISATION EN COURS..." Opacity="0.3" FontWeight="Black" LetterSpacing="2" />
                                        <ProgressBar IsIndeterminate="True" Width="150" IsVisible="{Binding IsConnecting}" Foreground="{StaticResource BlueBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Border BorderBrush="{StaticResource AmberBrush}" BorderThickness="2,2,0,0" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <Border BorderBrush="{StaticResource AmberBrush}" BorderThickness="0,0,2,2" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                        <StackPanel Spacing="40" Margin="30">
                            <StackPanel Spacing="30">
                                <TextBlock Text="[ 03 ] CONFIGURATION DE L'UNITÉ" FontWeight="Black" FontSize="14" Foreground="{StaticResource AmberBrush}" />
                                <StackPanel Spacing="15">
                                    <TextBlock Text="PROFIL DE MISSION" FontSize="11" Opacity="0.6" LetterSpacing="2" />
                                    <ComboBox SelectedIndex="{Binding SelectedRole}" HorizontalAlignment="Stretch" Background="#15FFFFFF" BorderBrush="{StaticResource AmberBrush}" BorderThickness="1" CornerRadius="0">
                                        <ComboBoxItem>ENTRAÎNEMENT SOLO (DÉFENSE + ATTAQUE)</ComboBoxItem>
                                        <ComboBoxItem>UNITÉ D'ASSAUT (ATTAQUANT)</ComboBoxItem>
                                        <ComboBoxItem>UNITÉ DE PROTECTION (DÉFENSEUR)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Spacing="15" IsVisible="{Binding !IsSoloMode}">
                                    <TextBlock Text="IDENTIFIANT DE LA SALLE DE GUERRE" FontSize="11" Opacity="0.6" LetterSpacing="2" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                                        <TextBox x:Name="RoomName" Watermark="ENTREZ LE CODE..." Background="#15FFFFFF" BorderBrush="#30FFFFFF" CornerRadius="0" IsEnabled="{Binding IsConnected}" Padding="10" />
                                        <Button Grid.Column="1" Content="INITIER LA LIAISON" Command="{Binding JoinSpecificGameCommand}" 
                                                CommandParameter="{Binding #RoomName.Text}" IsEnabled="{Binding IsConnected}" Classes="Flat" Background="{StaticResource AmberBrush}" Foreground="Black" FontWeight="Black" CornerRadius="0" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#20FFFFFF" />
                            <StackPanel VerticalAlignment="Bottom" Spacing="20">
                                <Button IsVisible="{Binding IsSoloMode}" Command="{Binding StartSoloCommand}" 
                                        HorizontalAlignment="Stretch" Height="120" Background="#10FFB000" BorderBrush="{StaticResource AmberBrush}" BorderThickness="2" CornerRadius="0">
                                    <StackPanel Orientation="Horizontal" Spacing="30" HorizontalAlignment="Center">
                                        <Canvas Width="40" Height="40">
                                            <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="{StaticResource AmberBrush}" Width="40" Height="40" Stretch="Uniform" />
                                        </Canvas>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="LANCER L'OPÉRATION" FontSize="32" FontWeight="Black" Foreground="{StaticResource AmberBrush}" LetterSpacing="5" />
                                            <TextBlock Text="DÉPLOIEMENT IMMÉDIAT DANS LE SECTEUR LOCAL" FontSize="10" Foreground="{StaticResource AmberBrush}" Opacity="0.5" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                                <Border IsVisible="{Binding !IsSoloMode}" Padding="30" Background="#08FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="INTERFACE MULTI-JOUEURS ACTIVE" FontWeight="Black" Foreground="{StaticResource AmberBrush}" HorizontalAlignment="Center" LetterSpacing="2" />
                                        <TextBlock Text="Sélectionnez une opération sur le terminal gauche ou créez une nouvelle salle pour synchroniser les unités." Opacity="0.4" TextAlignment="Center" TextWrapping="Wrap" FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- SALLE D'ATTENTE -->
        <Border Background="#F0020408" IsVisible="{Binding IsWaitingRoomVisible}" ZIndex="250">
            <Grid Width="800" Height="600">
                <Border BorderBrush="{StaticResource BlueBrush}" BorderThickness="2" Opacity="0.2" />
                <StackPanel Spacing="50" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="SYNCHRONISATION DES UNITÉS" FontSize="28" FontWeight="Black" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" LetterSpacing="10" TextWrapping="Wrap" TextAlignment="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="60">
                        <StackPanel Grid.Column="0" Spacing="20">
                            <Border Width="180" Height="180" BorderBrush="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="2" Padding="10">
                                <Grid>
                                    <Rectangle Fill="{Binding IsReady, Converter={StaticResource ReadyToColorConverter}}" Opacity="0.1" />
                                    <TextBlock Text="PILOTE LOCAL" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold" Margin="0,10" />
                                    <TextBlock Text="PRÊT" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="32" FontWeight="Black" IsVisible="{Binding IsReady}" />
                                    <TextBlock Text="ATTENTE" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontWeight="Black" Opacity="0.3" IsVisible="{Binding !IsReady}" />
                                </Grid>
                            </Border>
                            <CheckBox Content="PRÊT AU COMBAT" IsChecked="{Binding IsReady}" Foreground="{StaticResource BlueBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="20">
                            <Border Width="180" Height="180" BorderBrush="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" BorderThickness="2" Padding="10">
                                <Grid>
                                    <Rectangle Fill="{Binding IsOpponentReady, Converter={StaticResource ReadyToColorConverter}}" Opacity="0.1" />
                                    <TextBlock Text="ADVERSAIRE DISTANT" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold" Margin="0,10" />
                                    <TextBlock Text="PRÊT" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="32" FontWeight="Black" IsVisible="{Binding IsOpponentReady}" />
                                    <TextBlock Text="RECHERCHE" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontWeight="Black" Opacity="0.3" IsVisible="{Binding !IsOpponentReady}" />
                                </Grid>
                            </Border>
                            <TextBlock Text="RECHERCHE DE SIGNAL..." Opacity="0.5" HorizontalAlignment="Center" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar IsIndeterminate="True" Width="500" Foreground="{StaticResource BlueBrush}" Height="4" />
                    <Button Content="ABANDONNER" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="{StaticResource HudDanger}" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- HUD EN JEU -->
        <Grid IsVisible="{Binding IsGameStarted}" Margin="20">
            <Grid ColumnDefinitions="300, *, 300" RowDefinitions="Auto, *, Auto">
                
                <!-- TOP BAR -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="{StaticResource BlueBrush}" BorderThickness="0,0,0,1" Padding="10" Margin="0,0,0,20">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TOWER FLUFFY // HUD TACTIQUE" FontWeight="Black" FontSize="14" Foreground="{StaticResource BlueBrush}" />
                            <TextBlock Text="FLUX TEMPS RÉEL // LIAISON SÉCURISÉE" FontSize="9" Opacity="0.4" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="60">
                            <StackPanel>
                                <TextBlock Text="INTÉGRITÉ BASE" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.BaseHealth}" FontSize="32" FontWeight="Black" Foreground="{StaticResource HudDanger}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="PHASE" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding PhaseFormatted}" FontSize="32" FontWeight="Black" Foreground="{StaticResource AmberBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="VAGUE" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.WaveNumber}" FontSize="32" FontWeight="Black" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Content="TERMINER" Command="{Binding ReplayCommand}" Classes="Basic" Foreground="{StaticResource HudDanger}" />
                    </Grid>
                </Border>

                <!-- LEFT PANEL: DEFENSE -->
                <Border Grid.Row="1" Grid.Column="0" Background="#10FFFFFF" BorderBrush="{StaticResource BlueBrush}" BorderThickness="1" Margin="0,0,20,0" Padding="15" IsVisible="{Binding CanPlaceTower}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="UNITÉS DE DÉFENSE" FontWeight="Black" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" />
                        <Border Background="#2000A3FF" Padding="10" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <TextBlock Text="CRÉDITS :" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.DefenderGold}" FontSize="24" FontWeight="Black" Foreground="{StaticResource BlueBrush}" />
                            </StackPanel>
                        </Border>
                        <Rectangle Height="1" Fill="#20FFFFFF" />
                        <StackPanel Spacing="10">
                            <Button Command="{Binding SetBasicTowerCommand}" HorizontalAlignment="Stretch" Padding="10" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=BasicShooter}">
                                <StackPanel>
                                    <TextBlock Text="TOUR BASIQUE" FontWeight="Bold" />
                                    <TextBlock Text="Coût: 10" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SetFlamethrowerCommand}" HorizontalAlignment="Stretch" Padding="10" Background="{Binding CurrentTowerType, Converter={StaticResource TowerTypeToBrushConverter}, ConverterParameter=Flamethrower}">
                                <StackPanel>
                                    <TextBlock Text="LANCE-FLAMMES" FontWeight="Bold" />
                                    <TextBlock Text="Coût: 25" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Border Background="#08FFFFFF" Padding="10">
                            <TextBlock Text="{Binding CurrentTowerStats}" FontSize="10" TextWrapping="Wrap" Foreground="{StaticResource AmberBrush}" />
                        </Border>
                        <Button Command="{Binding SkipPreparationCommand}" IsVisible="{Binding IsPreparationTimerVisible}" Content="FORCER LA VAGUE" Classes="Flat" Background="{StaticResource HudDanger}" Foreground="White" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- CENTER -->
                <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform">
                    <controls:GameBoardControl Snapshot="{Binding Snapshot}" PlaceTowerCommand="{Binding PlaceTowerCommand}" />
                </Viewbox>

                <!-- RIGHT PANEL: ATTACK -->
                <Border Grid.Row="1" Grid.Column="2" Background="#10FFFFFF" BorderBrush="{StaticResource HudDanger}" BorderThickness="1" Margin="20,0,0,0" Padding="15" IsVisible="{Binding CanSendUnits}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="FORCE D'ASSAUT" FontWeight="Black" Foreground="{StaticResource HudDanger}" HorizontalAlignment="Center" />
                        <Border Background="#20FF3C00" Padding="10" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <TextBlock Text="BUDGET :" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Snapshot.Hud.AttackerBudget}" FontSize="24" FontWeight="Black" Foreground="{StaticResource HudDanger}" />
                            </StackPanel>
                        </Border>
                        <Rectangle Height="1" Fill="#20FFFFFF" />
                        <StackPanel Spacing="10">
                            <Button Command="{Binding SendSoldatCommand}" HorizontalAlignment="Stretch" Padding="10" IsEnabled="{Binding !IsPreparationTimerVisible}">
                                <StackPanel>
                                    <TextBlock Text="DÉPLOYER SOLDAT" FontWeight="Bold" />
                                    <TextBlock Text="Coût: 10" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SendBruteCommand}" HorizontalAlignment="Stretch" Padding="10" IsEnabled="{Binding !IsPreparationTimerVisible}">
                                <StackPanel>
                                    <TextBlock Text="DÉPLOYER BRUTE" FontWeight="Bold" />
                                    <TextBlock Text="Coût: 50" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Border Background="#08FFFFFF" Padding="10">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Snapshot.Units.Count, StringFormat='UNITÉS ACTIVES : {0}'}" FontSize="12" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- BOTTOM BAR -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="{StaticResource BlueBrush}" BorderThickness="0,1,0,0" Padding="10" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="*, *, *">
                        <TextBlock Grid.Column="0" Text="FLUX TACTIQUE ACTIF" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                            <TextBlock Text="{Binding ActivePhaseLabel}" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ActivePhaseTime}" FontSize="24" FontWeight="Black" Foreground="{StaticResource AmberBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="60 FPS // SECURE" FontSize="10" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>

            <!-- OVERLAY END -->
            <Border IsVisible="{Binding IsGameFinished}" Background="#E0000000" ZIndex="1000">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="30">
                    <TextBlock Text="FIN DE MISSION" FontSize="48" FontWeight="Black" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding GameResultMessage}" FontSize="32" FontWeight="Bold" Foreground="{Binding GameResultColor}" HorizontalAlignment="Center" />
                    <Button Content="RETOURNER AU QG" Command="{Binding ReplayCommand}" Width="200" HorizontalAlignment="Center" Classes="Flat" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>
